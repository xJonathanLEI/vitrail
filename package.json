{
  "name": "vitrail",
  "private": true,
  "scripts": {
    "prisma": "prisma",
    "format": "biome format --write .",
    "format:check": "biome check --formatter-enabled=true .",
    "typecheck": "tsc --project tests/d1/tsconfig.json",
    "generate:prisma-fixtures": "node scripts/prisma-fixtures.mjs generate",
    "generate:prisma-fixtures:postgres": "node scripts/prisma-fixtures.mjs postgres",
    "generate:prisma-fixtures:sqlite": "node scripts/prisma-fixtures.mjs sqlite",
    "test:d1": "vitest run --config tests/d1/vitest.config.ts",
    "test:d1:direct": "npm run test:d1 -- --project miniflare tests/direct-crud.test.ts",
    "test:d1:sessions": "npm run test:d1 -- --project miniflare tests/sessions.test.ts",
    "test:d1:batches": "npm run test:d1 -- --project miniflare tests/atomic-batches.test.ts",
    "test:d1:miniflare": "npm run test:d1 -- --project miniflare",
    "test:d1:wrangler": "npm run test:d1 -- --project wrangler"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^24.13.3",
    "miniflare": "4.20260714.0",
    "prisma": "7.5.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "wrangler": "4.112.0"
  }
}
